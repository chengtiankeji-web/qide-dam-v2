# ===== QideDAM v2 environment template =====
# Copy to .env (dev) or .env.production and fill in real values.
# NEVER commit .env / .env.production.

# --- Core ---
APP_NAME="QideDAM"
APP_ENV=development                # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080           # 7 days

# --- DB ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=qidedam
POSTGRES_USER=qidedam
POSTGRES_PASSWORD=CHANGE_ME_dev_password
DATABASE_URL=postgresql+asyncpg://qidedam:CHANGE_ME_dev_password@postgres:5432/qidedam
DATABASE_URL_SYNC=postgresql+psycopg2://qidedam:CHANGE_ME_dev_password@postgres:5432/qidedam

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Object storage (S3 protocol) ---
# Local dev: MinIO — endpoint http://minio:9000
# Production: Cloudflare R2 — endpoint https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=qidedam-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_PUBLIC_BASE_URL=http://localhost:9000/qidedam-dev   # dev preview; in prod replace with cdn.qide.com or signed URL

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://qingxuantech.work,https://aivisible.top

# --- Multi-tenant default ---
DEFAULT_TENANT_SLUG=qide
DEFAULT_PROJECT_SLUG=core

# --- AI (Sprint 3) ---
DASHSCOPE_API_KEY=
OPENAI_API_KEY=

# --- WeCom notification (optional) ---
WECOM_BOT_URL=

# --- MCP server ---
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8001
MCP_API_KEY_HEADER=X-DAM-API-Key
